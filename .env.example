# Copy this file to .env and fill in your real values.
# Never commit your actual .env file.

# Postgres connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<database_name>
#
# Examples:
#   Local Postgres:
#     postgresql://postgres:postgres@localhost:5432/clinic_db
#
#   Render / Railway / Supabase / Neon (copy from their dashboard):
#     postgresql://user:password@host.region.provider.com:5432/dbname
#
# If DATABASE_URL is not set, the app falls back to a local SQLite
# file (clinic.db) for convenience during development -- but note that
# SQLite data will NOT persist on most hosting platforms.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clinic_db
